APP_NAME="Claread透读"
APP_ENV="development"
LOG_LEVEL="INFO"

DATABASE_URL="postgresql://claread:claread_dev@127.0.0.1:5432/claread"
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_MAX_INACTIVE_CONNECTION_LIFETIME=3600

REDIS_ENABLED=false
REDIS_URL="redis://127.0.0.1:6379/0"

WECHAT_APP_ID=""
WECHAT_APP_SECRET=""
AUTH_SESSION_EXPIRY_DAYS=30

PHONE_AUTH_PROVIDER="mock"
PHONE_MOCK_VERIFICATION_CODE="888888"
# Set PHONE_AUTH_PROVIDER="aliyun_dypnsapi" to use Alibaba Cloud Dypnsapi.
# The provider also falls back to ALIBABA_CLOUD_ACCESS_KEY_ID /
# ALIBABA_CLOUD_ACCESS_KEY_SECRET when the ALIYUN_DYPNSAPI_* keys are empty.
ALIYUN_DYPNSAPI_ACCESS_KEY_ID=""
ALIYUN_DYPNSAPI_ACCESS_KEY_SECRET=""
ALIYUN_DYPNSAPI_ENDPOINT="dypnsapi.aliyuncs.com"
ALIYUN_DYPNSAPI_REGION_ID="cn-hangzhou"
ALIYUN_DYPNSAPI_SIGN_NAME=""
ALIYUN_DYPNSAPI_LOGIN_TEMPLATE_CODE="100001"
ALIYUN_DYPNSAPI_CODE_TTL_MINUTES=5
ALIYUN_DYPNSAPI_CODE_LENGTH=6
ALIYUN_DYPNSAPI_SEND_INTERVAL_SECONDS=60

DEFAULT_MODEL_PROFILE=""
ANNOTATION_MODEL_PROFILE=""
DAILY_ANNOTATION_MODEL_PROFILE=""
DAILY_ANALYSIS_MODEL_PROFILE=""
DAILY_REVIEW_MODEL_PROFILE=""
MODEL_PROFILES_JSON="config/model-profiles.json"
MODEL_PRESETS_JSON=""

LANGSMITH_ENABLED=false
LANGSMITH_TRACING=true
LANGSMITH_PROJECT="claread-dev"
LANGSMITH_API_KEY=""
LANGSMITH_ENDPOINT="https://api.smith.langchain.com"
LANGSMITH_WORKSPACE_ID=""

GUARDIAN_API_KEY=""
DAILY_READER_ADMIN_OPENID=""
DAILY_READER_ADMIN_API_KEY=""
SERVER_BASE_URL="http://127.0.0.1:8000"

GRAMMAR_RAG_ENABLED=false
ZILLIZ_URI=""
ZILLIZ_TOKEN=""
ZILLIZ_COLLECTION_GRAMMAR_NOTE="grammar_note_examples"
ZILLIZ_COLLECTION_SENTENCE_ANALYSIS="sentence_analysis_examples"
BAILIAN_API_KEY=""
BAILIAN_EMBEDDING_MODEL="text-embedding-v4"
BAILIAN_EMBEDDING_DIMENSION=1024
BAILIAN_RERANK_MODEL="qwen3-rerank"
GRAMMAR_RAG_ANN_TOPK=8
GRAMMAR_RAG_RERANK_TOPN=5
GRAMMAR_RAG_CONFIDENCE_THRESHOLD=0.3

INTERNAL_API_KEY=""
